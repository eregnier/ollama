@@ -4602,9 +4602,16 @@ int ggml_metal_op_tq_flash_attn_ext(ggml_metal_op_t ctx, int idx) {
         /*.nb31         =*/ mask ? mask->nb[1] : 0,
     };
 
+    // Select D=128 vs D=256 pipeline. Gemma3 runs at headDim=256; everything
